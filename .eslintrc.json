{
  "root": true,
  "env": {
    "browser": true,
    "es2022": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-undef": "error",
    "no-console": "off",
    "semi": ["warn", "always"],
    "quotes": ["warn", "double"],
    "eqeqeq": ["error", "always"],
    "no-var": "error",
    "prefer-const": "warn",
    "indent": ["warn", 4]
  }
}
